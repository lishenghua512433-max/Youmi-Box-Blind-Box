# ===========================================
# Youmi Box Blind Box - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# Supabase Database (Required)
COZE_SUPABASE_URL=https://xxxxx.supabase.co
COZE_SUPABASE_ANON_KEY=eyJxxx...
COZE_SUPABASE_SERVICE_ROLE_KEY=eyJxxx...

# BSC Blockchain - Payout Wallet (Required for auto-payout)
# This is the PRIVATE KEY of the payout wallet (used for auto-sending USDT to users)
# ⚠️ SECURITY: Never commit this to git! Keep it secret!
PAYOUT_PRIVATE_KEY=0x_your_payout_wallet_private_key_here

# BSC RPC Endpoint (Optional - defaults to public BSC RPC)
BSC_RPC_URL=https://bsc-dataseed.binance.org

# ===========================================
# Admin Settings (configured via admin panel, not env vars)
# - collection_wallet: Where user payments go
# - payout_wallet: Where platform sends payouts from
# - usdt_contract: BSC USDT contract address
# - busd_contract: BSC BUSD contract address  
# - trx_contract: BSC TRX contract address
# ===========================================
