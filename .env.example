# ===========================================
# Youmi Box Blind Box - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
#
# ⚠️ ALL 3 Supabase variables are REQUIRED.
#    Without COZE_SUPABASE_SERVICE_ROLE_KEY, API routes will fail with RLS errors.
#    Find them at: Supabase Dashboard → Settings → API

# Supabase Database (ALL 3 REQUIRED)
COZE_SUPABASE_URL=https://xxxxx.supabase.co
COZE_SUPABASE_ANON_KEY=eyJxxx...
COZE_SUPABASE_SERVICE_ROLE_KEY=eyJxxx...  # ⚠️ REQUIRED! API routes use this to bypass RLS

# BSC Blockchain - Payout Contract Private Key (Required for auto-payout)
# This is the PRIVATE KEY of the contract owner wallet (used for calling payout/withdraw on YoumiPayoutPool contract)
# ⚠️ CRITICAL SECURITY RULES:
#   1. NEVER commit .env.local to git — .gitignore blocks it, but double-check!
#   2. NEVER expose this key in frontend code — backend only (server-side reads process.env)
#   3. NEVER log this key in console.log or error messages
#   4. NEVER share this key via API response or client-facing code
#   5. This wallet must be the contract owner (the wallet that deployed the contract)
PAYOUT_WALLET_PRIVATE_KEY=0x_your_admin_wallet_private_key_here

# BSC RPC Endpoint (Optional - defaults to public BSC RPC)
BSC_RPC_URL=https://bsc-dataseed.binance.org

# ===========================================
# Admin Settings (configured via admin panel, not env vars)
# - collection_wallet: Where user blind box payments go (your private wallet)
# - payout_wallet: Admin wallet address (contract owner)
# - payout_contract_address: YoumiPayoutPool contract address (deployed on BSC)
# - usdt_contract: BSC USDT contract address
# - busd_contract: BSC BUSD contract address
# - trx_contract: BSC TRX contract address (BEP20)
#
# Fund Flow:
#   Blind box purchase → collection_wallet (your private wallet)
#   Trade fees → collection_wallet (your private wallet)
#   NFT recycle payout → YoumiPayoutPool contract → user wallet
#   Commission payout → YoumiPayoutPool contract → user wallet
# ===========================================
